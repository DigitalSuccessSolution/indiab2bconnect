generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client_v3"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String     @id @default(uuid())
  name             String?
  email            String?    @unique
  phone            String?    @unique
  password         String?
  googleId         String?    @unique
  avatar           String?
  role             Role       @default(BUYER)
  isActive         Boolean    @default(true)
  twoFactorSecret  String?
  twoFactorEnabled Boolean    @default(false)
  
  // New Fields
  lastLoginAt      DateTime?
  loginCount       Int       @default(0)
  phoneVerified    Boolean   @default(false)
  emailVerified    Boolean   @default(false)
  
  otp              String?
  otpExpiry        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  
  auditLogs        AuditLog[]
  reviewsWritten   Review[]   @relation("ReviewsWritten")
  admin            Admin?
  vendor           Vendor?
  
  notifications    Notification[]
  refreshTokens    RefreshToken[]
  verificationTokens VerificationToken[]

  @@index([role])
  @@index([isActive])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model VerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  type      String   // "OTP", "EMAIL_VERIFY", "PASSWORD_RESET"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Admin {
  id          String   @id @default(uuid())
  userId      String   @unique
  name        String
  email       String   @unique
  permissions String[]
  department  String   @default("GENERAL")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  categoryIds String[]
  hubName     String?
  createdById String?
  user        User     @relation(fields: [userId], references: [id])
  createdBy   Admin?   @relation("AdminToSubAdmin", fields: [createdById], references: [id])
  subAdmins   Admin[]  @relation("AdminToSubAdmin")

  @@map("SubAdmin")
}

model Vendor {
  id                   String          @id @default(uuid())
  userId               String          @unique
  businessName         String
  email                String
  phone                String
  gstNumber            String?
  aadhaarNumber        String?
  city                 String
  verified             Boolean         @default(false)
  status               VendorStatus?
  trustBadge           TrustBadge      @default(NONE)
  verificationDocument String?
  logoUrl              String?
  profileCompleteness  Int             @default(0)
  responseTime         Float           @default(0)
  loginFrequency       Int             @default(0)
  leadClosureRate      Float           @default(0)
  totalScore           Float           @default(0)
  manualBoost          Float           @default(0)
  packageId            String?
  planExpiry           DateTime?
  description          String?
  address              String?
  socialLinks          Json?
  googleBusinessLink   String?
  workingHours         String?
  rejectionReason      String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  certifications       Certification[]
  gallery              GalleryImage[]
  legacyLeads          Lead[]          @relation("LegacyVendorLeads")
  products             Product[]
  rankings             Ranking[]
  refunds              Refund[]
  reviewsReceived      Review[]        @relation("ReviewsReceived")
  transactions         Transaction[]
  package              Package?        @relation(fields: [packageId], references: [id])
  user                 User            @relation(fields: [userId], references: [id])
  categories           Category[]      @relation("CategoryToVendor")
  keywords             Keyword[]       @relation("KeywordToVendor")

  @@index([status])
  @@index([city])
  @@index([verified])
  @@index([totalScore])
  @@index([packageId])
  @@index([planExpiry])
  @@index([createdAt])
  @@index([status, createdAt])
}

model GalleryImage {
  id        String   @id @default(uuid())
  vendorId  String
  url       String
  publicId  String
  createdAt DateTime @default(now())
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

model Certification {
  id        String   @id @default(uuid())
  vendorId  String
  name      String
  url       String
  createdAt DateTime @default(now())
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  leads       Lead[]
  vendors     Vendor[] @relation("CategoryToVendor")
}

model Keyword {
  id      String   @id @default(uuid())
  name    String   @unique
  vendors Vendor[] @relation("KeywordToVendor")
}

model Product {
  id             String         @id @default(uuid())
  vendorId       String
  name           String
  description    String?
  price          Float?
  category       String?
  type           OfferingType   @default(PRODUCT)
  status         OfferingStatus @default(PENDING)
  moq            Int?           @default(1)
  availability   Boolean        @default(true)
  sku            String?
  specifications String?
  rejectionReason String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  images         String[]       @default([])
  keywords       String[]       @default([])
  vendor         Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  reviews        Review[]

  @@index([vendorId])
  @@index([status])
  @@index([type])
  @@index([vendorId, status])
  @@index([status, availability])
  @@index([createdAt])
}

model Lead {
  id            String          @id @default(uuid())
  buyerName     String
  phone         String
  city          String
  categoryId    String
  type          LeadType        @default(INQUIRY)
  searchKeyword String?
  message       String?
  vendorId      String?
  status        LeadStatus      @default(PENDING)
  followUpSent  Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  category      Category        @relation(fields: [categoryId], references: [id])
  vendor        Vendor?         @relation("LegacyVendorLeads", fields: [vendorId], references: [id], onDelete: SetNull)
  lifecycle     LeadLifecycle[]

  @@index([vendorId])
  @@index([status])
  @@index([categoryId])
  @@index([city])
  @@index([type])
  @@index([createdAt])
  @@index([vendorId, status])
  @@index([searchKeyword])
}

model LeadLifecycle {
  id        String   @id @default(uuid())
  leadId    String
  action    String
  details   String?
  createdAt DateTime @default(now())
  vendorId  String?
  lead      Lead     @relation(fields: [leadId], references: [id])

  @@index([leadId])
}

model Package {
  id            String        @id @default(uuid())
  name          String        @unique
  price         Float
  priority      Int           @default(0)
  rankingWeight Float         @default(0)
  description   String?
  features      String[]      @default([])
  isPopular     Boolean       @default(false)
  isActive      Boolean       @default(true)
  transactions  Transaction[]
  vendors       Vendor[]
}

model Transaction {
  id                String            @id @default(uuid())
  vendorId          String
  packageId         String?
  amount            Float
  currency          String            @default("INR")
  status            TransactionStatus @default(PENDING)
  paymentGateway    String            @default("PHONEPE") // PHONEPE, RAZORPAY
  gatewayOrderId    String?           @unique
  gatewayTransactionId String?        @unique
  invoiceUrl        String?
  type              String            @default("PURCHASE")
  subscriptionDays  Int               @default(30)
  expiryAt          DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  refund            Refund?
  package           Package?          @relation(fields: [packageId], references: [id])
  vendor            Vendor            @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([status])
  @@index([createdAt])
  @@index([vendorId, status])
}

model Refund {
  id               String       @id @default(uuid())
  vendorId         String
  transactionId    String       @unique
  amount           Float
  reason           String
  status           RefundStatus @default(REQUESTED)
  adminNote        String?
  gatewayRefundId  String?
  processedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  transaction      Transaction  @relation(fields: [transactionId], references: [id])
  vendor           Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([status])
  @@index([createdAt])
}

model Ranking {
  id       String   @id @default(uuid())
  vendorId String
  score    Float
  date     DateTime @default(now())
  vendor   Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([vendorId, date])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  vendorId  String
  productId String?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  product   Product? @relation(fields: [productId], references: [id])
  user      User     @relation("ReviewsWritten", fields: [userId], references: [id])
  vendor    Vendor   @relation("ReviewsReceived", fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([productId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  module    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@index([module, action, createdAt])
}

model SystemSettings {
  id                       String   @id @default("global")
  rankingWeightProfile     Float    @default(0.4)
  rankingWeightPerformance Float    @default(0.6)
  maxLeadsPerVendorPerDay  Int      @default(10)
  updatedAt                DateTime @updatedAt
  alertInquirySpikes       Boolean  @default(false)
  alertPaymentExceptions   Boolean  @default(true)
  alertVendorOnboarding    Boolean  @default(true)
  hubName                  String   @default("Mumbai Central")
  marketplaceId            String   @default("B2B-INDIA-ROOT-01")
}

model GlobalSettings {
  id              String   @id @default("global")
  websiteName     String   @default("India B2B Connect")
  contactEmail    String   @default("contact@indiab2bconnect.com")
  contactPhone    String   @default("+91 0000000000")
  address         String   @default("India")
  logoUrl         String?
  facebookUrl     String?
  twitterUrl      String?
  instagramUrl    String?
  linkedinUrl     String?
  youtubeUrl      String?
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  primaryColor    String   @default("#164e33")
  secondaryColor  String   @default("#ffffff")
  updatedAt       DateTime @updatedAt
  googleAdSenseId String?
}

enum Role {
  ADMIN
  SUBADMIN
  SUPERADMIN
  VENDOR
  BUYER
}

enum LeadType {
  IDLE
  DIRECT
  INQUIRY
}

enum LeadStatus {
  PENDING
  DISTRIBUTED
  CLOSED
  EXPIRED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSED
}

enum OfferingType {
  PRODUCT
  SERVICE
}

enum OfferingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VendorStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum TrustBadge {
  NONE
  VERIFIED
  GOLD_SUPPLIER
  TRUST_SEAL
}

enum InquiryStatus {
  PENDING
  INPROGRESS
  RESOLVED
}

model ContactInquiry {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    InquiryStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}
